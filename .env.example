# ============================================================
# Firebase 環境變數（複製本檔為 .env 並填入你的專案設定）
# 取得位置：Firebase Console → 專案設定 → 你的應用程式 → SDK 設定/設定檔
# 當這些欄位都填好後，前端會自動改用 Firestore（永久雲端儲存）；
# 若留空或缺少，應用會降級為 localStorage（僅本機、單機，非共享）。
#
# 重要：本專案只用 Firebase Spark 免費層（免計費、免信用卡）。
#   不使用 Cloud Storage for Firebase（Spark 方案不提供，需 Blaze 計費）。
#   附件直接以 base64 內嵌進 Firestore 文件，受單文件 1MB 限制。
# ============================================================

VITE_FB_API_KEY=AIzaSyDxxxxxxx
VITE_FB_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FB_PROJECT_ID=your-project
VITE_FB_MESSAGING_SENDER_ID=1234567890
VITE_FB_APP_ID=1:1234567890:web:abcdef123456

# 應用程式識別碼（用於 Firestore 路徑隔離，可自訂）
VITE_FB_APP_ID_SLUG=esggo-learning-center

# 管理員密碼（僅用於「切換管理背景角」的輕量保護，非真正身分認證）。
# 正式環境建議改為 Firebase Auth 自訂聲明或 Firebase 後端。
VITE_ADMIN_PASS=change-me
