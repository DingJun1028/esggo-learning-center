rules_version = '2';

// 資料模型：
//   /artifacts/{appId}/public/data/submissions/{docId}
//     - 匿名登入的學員都能讀寫（課程平台開放提交）
//     - 單一文件大小上限 1MB（大附件以 base64 內嵌於文件中，總量在前端限制 700KB）
//     - 本專案不使用 Cloud Storage（Spark 免費方案不提供，需 Blaze 計費），附件內嵌 Firestore
service cloud.firestore {
  match /databases/{database}/documents {
    match /artifacts/{appId}/public/data/submissions/{docId} {
      allow read, create, update, delete: if request.auth != null
        && request.resource.size() <= 1 * 1024 * 1024;
    }
  }
}
